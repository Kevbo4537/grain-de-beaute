---
import Base from '../layouts/Base.astro';
import { url } from '../data';
import { galleryPairs } from '../gallery';
---
<Base title="Galerie avant/après sourcils | Grain de Beauté Monnaie" description="Galerie avant/après Grain de Beauté : photos de technique mixte sourcils à Monnaie près de Tours, publiées avec accord et optimisées pour le web." canonical="/galerie/">
  <section>
    <div class="eyebrow">Avant/après</div>
    <h1>Galerie sourcils avant/après</h1>
    <p>Découvrez des exemples de sourcils restructurés avec un rendu plus net, plus harmonieux et adapté au visage. Les photos sont intégrées sans nom de cliente et optimisées pour le web.</p>
    <p>La publication d’une photo avant/après nécessite toujours un accord explicite. Une photo peut être retirée sur demande.</p>
  </section>
  <section class="section-soft">
    <div class="pair-grid">
      {galleryPairs.map((pair) => (
        <article class="pair-card">
          <div class="pair-images">
            <figure><span>Avant</span><img src={url(pair.before)} alt={pair.beforeAlt} loading="lazy" /></figure>
            <figure><span>Après</span><img src={url(pair.after)} alt={pair.afterAlt} loading="lazy" /></figure>
          </div>
          <div class="pair-content">
            <span>{pair.category}</span>
            <h2>{pair.title}</h2>
            <p>{pair.caption}</p>
          </div>
        </article>
      ))}
    </div>
    <div class="cta-row"><a class="btn" href={url('demande-avis-sourcils/')}>Demander un avis</a><a class="btn outline" href={url('technique-mixte-sourcils/')}>Comprendre la technique</a></div>
  </section>
</Base>
