---
import Base from '../layouts/Base.astro';
import { url } from '../data';
import { galleryPairs } from '../gallery';
---
<Base title="Galerie avant/après sourcils | Grain de Beauté Monnaie" description="Photos avant/après de technique mixte sourcils à Monnaie près de Tours : exemples de restructuration, microblading et microshading." canonical="/galerie/">
  <section>
    <div class="eyebrow">Avant/après</div>
    <h1>Galerie sourcils avant/après</h1>
    <p>Ces exemples permettent de visualiser le travail de restructuration des sourcils : ligne plus nette, regard visuellement plus structuré et intensité adaptée au visage.</p>
    <p>Les photos sont publiées sans nom de cliente. Elles ne sont mises en ligne qu’avec accord, et peuvent être retirées sur demande.</p>
  </section>
  <section class="section-soft">
    <div class="pair-grid">
      {galleryPairs.map((pair) => (
        <article class="pair-card">
          <div class="pair-images">
            <figure><span>Avant</span><img src={url(pair.before)} alt={pair.beforeAlt} loading="lazy" /></figure>
            <figure><span>Après</span><img src={url(pair.after)} alt={pair.afterAlt} loading="lazy" /></figure>
          </div>
          <div class="pair-content">
            <span>{pair.category}</span>
            <h2>{pair.title}</h2>
            <p>{pair.caption}</p>
          </div>
        </article>
      ))}
    </div>
    <div class="cta-row"><a class="btn" href={url('demande-avis-sourcils/')}>Demander un avis</a><a class="btn outline" href={url('technique-mixte-sourcils/')}>Comprendre la technique</a></div>
  </section>
</Base>
